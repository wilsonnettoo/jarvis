# =====================================================================
# Jarvis — variáveis de ambiente
# Copie este arquivo para `.env` e preencha as chaves que for usar.
# Você NÃO precisa preencher todas: só as do provedor que vai usar.
# =====================================================================

# ---------------------------------------------------------------------
# Provedor e modelo do "cérebro" (LLM)
# O Jarvis usa LiteLLM, então o modelo segue o formato do LiteLLM.
# Exemplos de JARVIS_MODEL:
#   OpenAI   -> gpt-4o            ou  gpt-4o-mini
#   Claude   -> claude-sonnet-4-6 (Anthropic)
#   Gemini   -> gemini/gemini-1.5-pro
#   Ollama   -> ollama/llama3.1   (local, precisa do Ollama rodando)
# ---------------------------------------------------------------------
JARVIS_MODEL=gpt-4o-mini

# Temperatura do modelo (0.0 = mais determinístico, 1.0 = mais criativo)
JARVIS_TEMPERATURE=0.4

# ---------------------------------------------------------------------
# Chaves de API (preencha apenas as que for usar)
# ---------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Ollama roda local; normalmente não precisa de chave.
# Descomente se seu Ollama estiver em outro host/porta:
# OLLAMA_API_BASE=http://localhost:11434

# ---------------------------------------------------------------------
# Banco de dados (ferramenta consultar_postgres; opcional)
# Ex.: postgresql://usuario:senha@localhost:5432/meubanco
# Requer: pip install 'psycopg[binary]'
# ---------------------------------------------------------------------
DATABASE_URL=

# ---------------------------------------------------------------------
# Voz (usado só nas fases finais; pode deixar em branco por enquanto)
# ---------------------------------------------------------------------
PICOVOICE_ACCESS_KEY=

# ---------------------------------------------------------------------
# Comportamento de segurança
# Se "true", ações de risco MÉDIO e ALTO sempre pedem confirmação.
# ---------------------------------------------------------------------
JARVIS_REQUIRE_CONFIRMATION=true
